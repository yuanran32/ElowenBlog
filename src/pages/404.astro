---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/common-utils';
---

<BaseLayout title="页面未找到" description="你访问的页面不存在" showHeader={false}>
    <div class="flex flex-col items-center justify-center py-20 text-center">
        <h1 class="font-serif text-6xl font-bold">404</h1>
        <p class="mt-4 text-lg text-muted">你访问的页面不存在或已被移除</p>
        <a
            href={withBase('/')}
            class="mt-8 inline-block rounded-full border border-dashed border-main px-6 py-2 transition-colors hover:bg-muted"
        >
            返回首页
        </a>
    </div>
</BaseLayout>
