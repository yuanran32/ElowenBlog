---
import ArrowRight from '../../assets/icons/arrow-right.svg';
import Subscribe from '../../components/Subscribe.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/common-utils';
import { getPublishedBlogPosts, getSeriesIndex } from '../../utils/data-utils';

const posts = await getPublishedBlogPosts();
const seriesList = getSeriesIndex(posts);
---

<BaseLayout title="系列" description="按系列浏览博客文章。" showHeader={false}>
    <h1 class="mb-12 font-serif text-2xl italic sm:mb-16 sm:text-4xl">文章系列</h1>
    {
        seriesList.map((series) => {
            return (
                <a class="group mb-10 flex items-start justify-between gap-8 sm:mb-12" href={withBase(`/series/${series.id}/`)}>
                    <div class="grow">
                        <h2 class="font-serif text-xl leading-tight font-medium group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4 sm:text-2xl">
                            {series.name}
                        </h2>
                        <div class="mt-1 text-sm leading-normal">{series.count} 篇文章</div>
                    </div>
                    <div class="hidden font-serif italic opacity-0 transition group-hover:opacity-100 sm:inline-flex sm:shrink-0 sm:items-center sm:gap-1">
                        查看系列文章 <ArrowRight class="h-4 w-4 fill-current" />
                    </div>
                </a>
            );
        })
    }
    <Subscribe class="my-16 sm:my-24" />
</BaseLayout>
