---
import { type CollectionEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostPreview from '../../components/PostPreview.astro';
import TocCard from '../../components/TocCard.astro';
import { getPublishedBlogPosts, getReadingTime } from '../../utils/data-utils';
import { absoluteUrl, slugify, withBase } from '../../utils/common-utils';

export async function getStaticPaths() {
    const posts = await getPublishedBlogPosts();
    const postCount = posts.length;
    return posts.map((post, index) => ({
        params: { id: post.id },
        props: {
            post,
            prevPost: index + 1 !== postCount ? posts[index + 1] : null,
            nextPost: index !== 0 ? posts[index - 1] : null
        }
    }));
}

type Props = { post: CollectionEntry<'blog'>; prevPost: CollectionEntry<'blog'>; nextPost: CollectionEntry<'blog'> };

const { href } = Astro.url;
const { post, prevPost, nextPost } = Astro.props;
const { title, publishDate, updatedDate, excerpt, tags = [], series, draft, seo } = post.data;
const { Content, headings } = await render(post);
const tableOfContents = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const readingTime = getReadingTime(post.body);
const postUrl = absoluteUrl(`/blog/${post.id}/`, Astro.site);
const articleJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description: seo?.description ?? excerpt,
    url: postUrl,
    image: absoluteUrl('/og-image.svg', Astro.site),
    datePublished: publishDate.toISOString(),
    dateModified: (updatedDate ?? publishDate).toISOString(),
    author: {
        '@type': 'Person',
        name: 'Elowen',
        url: 'https://github.com/yuanran32'
    },
    publisher: {
        '@type': 'Person',
        name: 'Elowen',
        url: 'https://github.com/yuanran32'
    },
    keywords: tags,
    articleSection: series,
    inLanguage: 'zh-CN'
};
---

<BaseLayout
    title={seo?.title ?? title}
    description={seo?.description ?? excerpt}
    image={seo?.image}
    pageType="article"
    showHeader={false}
    mainClass="mx-auto w-full max-w-3xl grow lg:relative"
    jsonLd={articleJsonLd}
>
    <div class="reading-progress fixed top-0 left-0 z-50 h-0.5 bg-current transition-[width] duration-100" style="width: 0%"></div>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm">
                {draft && <span class="mr-2">草稿</span>}
                <FormattedDate date={publishDate} />
                <span> · {readingTime} 分钟阅读</span>
                {
                    updatedDate && (
                        <>
                            {' '}
                            <span>
                                (更新于 <FormattedDate date={updatedDate} />)
                            </span>
                        </>
                    )
                }
            </div>
            {
                (series || tags.length > 0) && (
                    <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm">
                        {series && <span>系列：{series}</span>}
                        {tags.map((tag) => (
                            <a class="text-main hover:underline" href={withBase(`/tags/${slugify(tag)}/`)}>
                                #{tag}
                            </a>
                        ))}
                    </div>
                )
            }
        </header>
        <div class="prose sm:prose-lg max-w-none">
            <Content />
        </div>
        <div class="mt-8 flex justify-end text-sm sm:mt-12 sm:text-base">
            <Button class="copy-url-button" aria-label="复制链接" data-url={href} data-tooltip-default="复制链接" data-tooltip-success="已复制">分享</Button>
        </div>
    </article>
    {
        (prevPost || nextPost) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 font-serif text-xl italic sm:mb-16 sm:text-2xl">继续阅读</h2>
                {nextPost && <PostPreview post={nextPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevPost && <PostPreview post={prevPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
    {
        tableOfContents.length > 0 && (
            <aside class="mb-10 xl:fixed xl:top-24 xl:right-8 xl:mb-0 xl:w-56 xl:max-w-[calc(50%-22rem)]" aria-label="文章目录">
                <TocCard headings={tableOfContents} />
            </aside>
        )
    }
</BaseLayout>

<button
    class="back-to-top fixed right-6 bottom-6 z-50 flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-dashed border-main bg-main opacity-0 transition-opacity hover:bg-muted"
    aria-label="返回顶部"
>
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="18 15 12 9 6 15"></polyline>
    </svg>
</button>

<script>
    function initBlogEnhancements() {
        const progress = document.querySelector<HTMLElement>('.reading-progress');
        const backToTop = document.querySelector<HTMLButtonElement>('.back-to-top');
        if (!progress || !backToTop) return;

        function onScroll() {
            const scrollTop = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            const percent = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
            progress!.style.width = `${percent}%`;
            backToTop!.style.opacity = scrollTop > window.innerHeight ? '1' : '0';
            backToTop!.style.pointerEvents = scrollTop > window.innerHeight ? 'auto' : 'none';
        }

        backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    }
    let tocObserver: IntersectionObserver | null = null;

    function initTocSpy() {
        const tocNav = document.querySelector<HTMLElement>('[data-toc-spy]');
        if (!tocNav) return;

        const links = Array.from(tocNav.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]'));
        if (links.length === 0) return;

        const idToLink = new Map<string, HTMLAnchorElement>();
        for (const link of links) {
            const id = decodeURIComponent(link.hash.slice(1));
            if (id) idToLink.set(id, link);
        }

        const headings = Array.from(document.querySelectorAll<HTMLElement>('article :is(h2, h3)')).filter((heading) => idToLink.has(heading.id));
        if (headings.length === 0) return;

        tocObserver?.disconnect();

        let activeId = '';
        const setActive = (id: string) => {
            if (id === activeId) return;
            activeId = id;
            for (const link of links) link.classList.remove('toc-active');
            idToLink.get(id)?.classList.add('toc-active');
        };

        tocObserver = new IntersectionObserver(
            (entries) => {
                const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
                if (visible.length > 0) setActive((visible[0].target as HTMLElement).id);
            },
            { rootMargin: '0px 0px -70% 0px', threshold: 0 }
        );

        for (const heading of headings) tocObserver.observe(heading);
        setActive(headings[0].id);
    }

    initBlogEnhancements();
    initTocSpy();
    document.addEventListener('astro:page-load', () => {
        initBlogEnhancements();
        initTocSpy();
    });
</script>
