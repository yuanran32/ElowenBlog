---
import { type CollectionEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostPreview from '../../components/PostPreview.astro';
import { getPublishedBlogPosts, getReadingTime } from '../../utils/data-utils';
import { absoluteUrl, slugify, withBase } from '../../utils/common-utils';

export async function getStaticPaths() {
    const posts = await getPublishedBlogPosts();
    const postCount = posts.length;
    return posts.map((post, index) => ({
        params: { id: post.id },
        props: {
            post,
            prevPost: index + 1 !== postCount ? posts[index + 1] : null,
            nextPost: index !== 0 ? posts[index - 1] : null
        }
    }));
}

type Props = { post: CollectionEntry<'blog'>; prevPost: CollectionEntry<'blog'>; nextPost: CollectionEntry<'blog'> };

const { href } = Astro.url;
const { post, prevPost, nextPost } = Astro.props;
const { title, publishDate, updatedDate, excerpt, tags = [], series, draft, seo } = post.data;
const { Content, headings } = await render(post);
const tableOfContents = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const readingTime = getReadingTime(post.body);
const postUrl = absoluteUrl(`/blog/${post.id}/`, Astro.site);
const articleJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description: seo?.description ?? excerpt,
    url: postUrl,
    image: absoluteUrl('/og-image.svg', Astro.site),
    datePublished: publishDate.toISOString(),
    dateModified: (updatedDate ?? publishDate).toISOString(),
    author: {
        '@type': 'Person',
        name: 'Elowen',
        url: 'https://github.com/yuanran32'
    },
    publisher: {
        '@type': 'Person',
        name: 'Elowen',
        url: 'https://github.com/yuanran32'
    },
    keywords: tags,
    articleSection: series,
    inLanguage: 'zh-CN'
};
---

<BaseLayout
    title={seo?.title ?? title}
    description={seo?.description ?? excerpt}
    image={seo?.image}
    pageType="article"
    showHeader={false}
    mainClass="mx-auto w-full max-w-3xl grow lg:relative"
    jsonLd={articleJsonLd}
>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm">
                {draft && <span class="mr-2">草稿</span>}
                <FormattedDate date={publishDate} />
                <span> · {readingTime} 分钟阅读</span>
                {
                    updatedDate && (
                        <>
                            {' '}
                            <span>
                                (更新于 <FormattedDate date={updatedDate} />)
                            </span>
                        </>
                    )
                }
            </div>
            {
                (series || tags.length > 0) && (
                    <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm">
                        {series && <span>系列：{series}</span>}
                        {tags.map((tag) => (
                            <a class="text-main hover:underline" href={withBase(`/tags/${slugify(tag)}/`)}>
                                #{tag}
                            </a>
                        ))}
                    </div>
                )
            }
        </header>
        <div class="prose sm:prose-lg max-w-none">
            <Content />
        </div>
        <div class="mt-8 flex justify-end text-sm sm:mt-12 sm:text-base">
            <Button class="copy-url-button" aria-label="复制链接" data-url={href} data-tooltip-default="复制链接" data-tooltip-success="已复制">分享</Button>
        </div>
    </article>
    {
        (prevPost || nextPost) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 font-serif text-xl italic sm:mb-16 sm:text-2xl">继续阅读</h2>
                {nextPost && <PostPreview post={nextPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevPost && <PostPreview post={prevPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
    {
        tableOfContents.length > 0 && (
            <aside class="mb-10 xl:fixed xl:top-24 xl:left-[calc(50%+24rem+4rem)] xl:mb-0 xl:w-72" aria-label="文章目录">
                <nav class="border-main bg-muted max-h-[calc(100vh-7rem)] overflow-y-auto border border-dashed px-5 py-4 text-sm">
                    <h2 class="mb-3 font-serif text-lg italic">目录</h2>
                    <ol class="space-y-2">
                        {tableOfContents.map((heading) => (
                            <li class:list={[heading.depth === 3 && 'pl-4']}>
                                <a class="hover:underline hover:underline-offset-2" href={`#${heading.slug}`}>
                                    {heading.text}
                                </a>
                            </li>
                        ))}
                    </ol>
                </nav>
            </aside>
        )
    }
</BaseLayout>
