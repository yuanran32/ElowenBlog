---
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import PostPreview from '../components/PostPreview.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import siteConfig from '../data/site-config';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFeaturedBlogPosts, getFeaturedProjects } from '../utils/data-utils';

const featuredPosts = await getFeaturedBlogPosts();
const featuredProjects = await getFeaturedProjects();
const focusAreas = siteConfig.focusAreas ?? [];
const homeJsonLd = [
    {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: siteConfig.title,
        url: siteConfig.website,
        description: siteConfig.description,
        inLanguage: 'zh-CN'
    },
    {
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: siteConfig.title,
        url: siteConfig.website,
        sameAs: ['https://github.com/yuanran32'],
        jobTitle: '前端开发 / 全栈开发'
    }
];
---

<BaseLayout description={siteConfig.description} jsonLd={homeJsonLd}>
    <Hero {...siteConfig.hero} />
    <section class="mb-16 sm:mb-24">
        <h2 class="mb-6 font-serif text-xl italic sm:text-2xl">当前关注</h2>
        <div class="flex flex-wrap gap-3">
            {focusAreas.map((area) => <span class="border-main bg-muted rounded-full border px-4 py-1.5 text-sm">{area}</span>)}
        </div>
    </section>
    {
        featuredPosts?.length > 0 && (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 font-serif text-xl italic sm:mb-16 sm:text-2xl">近期文章</h2>
                {featuredPosts.map((post) => (
                    <PostPreview post={post} class="mb-10 sm:mb-12" headingLevel="h3" />
                ))}
                <div class="mt-12 sm:mt-16">
                    <Button href="/blog/">查看全部文章</Button>
                </div>
            </div>
        )
    }
    {
        featuredProjects?.length > 0 && (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 font-serif text-xl italic sm:mb-16 sm:text-2xl">精选项目</h2>
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    {featuredProjects.map((project) => (
                        <ProjectPreview project={project} headingLevel="h3" />
                    ))}
                </div>
                <div class="mt-12 sm:mt-16">
                    <Button href="/projects/">查看全部项目</Button>
                </div>
            </div>
        )
    }
</BaseLayout>
