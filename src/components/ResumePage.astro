---
import Button from './Button.astro';
import resumeData from '../data/resume-data';

const { name, title, summary, contactLinks, skillGroups, projects, experiences, education } = resumeData;
---

<article class="mb-16 sm:mb-24">
    <header class="mb-12 sm:mb-16">
        <p class="mb-3 text-sm">{title}</p>
        <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight">{name}</h1>
        <p class="mt-5 max-w-2xl text-base leading-relaxed sm:text-lg">{summary}</p>
        <div class="mt-7 flex flex-wrap gap-3">
            <Button href="mailto:3916048194@qq.com">联系我</Button>
            <Button href="https://github.com/yuanran32">GitHub</Button>
        </div>
    </header>

    <section class="mb-12 sm:mb-16">
        <h2 class="mb-5 font-serif text-xl italic sm:text-2xl">基本信息</h2>
        <div class="border-main grid gap-4 border border-dashed p-5 text-sm sm:grid-cols-3">
            {
                contactLinks.map((link) => (
                    <div>
                        <div class="mb-1 opacity-75">{link.label}</div>
                        <a class="break-all hover:underline hover:underline-offset-2" href={link.href}>
                            {link.value}
                        </a>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="mb-12 sm:mb-16">
        <h2 class="mb-5 font-serif text-xl italic sm:text-2xl">技术栈</h2>
        <div class="grid gap-4 sm:grid-cols-2">
            {
                skillGroups.map((group) => (
                    <section class="border-main border border-dashed p-5">
                        <h3 class="mb-3 font-serif text-lg font-medium">{group.title}</h3>
                        <div class="flex flex-wrap gap-2">
                            {group.skills.map((skill) => (
                                <span class="border-main bg-muted rounded-full border px-3 py-1 text-xs">{skill}</span>
                            ))}
                        </div>
                    </section>
                ))
            }
        </div>
    </section>

    <section class="mb-12 sm:mb-16">
        <h2 class="mb-5 font-serif text-xl italic sm:text-2xl">项目经历</h2>
        <div class="space-y-6">
            {
                projects.map((project) => (
                    <section class="border-main border border-dashed p-5">
                        <div class="mb-4">
                            <h3 class="font-serif text-xl leading-tight font-medium">{project.title}</h3>
                            <p class="mt-2 text-sm leading-relaxed">{project.description}</p>
                        </div>
                        <div class="mb-4 flex flex-wrap gap-2">
                            {project.techStack.map((tech) => (
                                <span class="border-main bg-muted rounded-full border px-3 py-1 text-xs">{tech}</span>
                            ))}
                        </div>
                        <ul class="space-y-2 text-sm leading-relaxed">
                            {project.highlights.map((highlight) => (
                                <li>{highlight}</li>
                            ))}
                        </ul>
                    </section>
                ))
            }
        </div>
    </section>

    <section class="mb-12 sm:mb-16">
        <h2 class="mb-5 font-serif text-xl italic sm:text-2xl">实习 / 工作经历</h2>
        <div class="space-y-6">
            {
                experiences.map((experience) => (
                    <section class="border-main border border-dashed p-5">
                        <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                            <h3 class="font-serif text-xl leading-tight font-medium">
                                {experience.company} - {experience.role}
                            </h3>
                            <p class="text-sm">{experience.period}</p>
                        </div>
                        <ul class="space-y-2 text-sm leading-relaxed">
                            {experience.highlights.map((highlight) => (
                                <li>{highlight}</li>
                            ))}
                        </ul>
                    </section>
                ))
            }
        </div>
    </section>

    <section class="mb-12 sm:mb-16">
        <h2 class="mb-5 font-serif text-xl italic sm:text-2xl">教育经历</h2>
        {
            education.map((edu) => (
                <div class="border-main border border-dashed p-5">
                    <h3 class="font-serif text-xl leading-tight font-medium">{edu.school}</h3>
                    <p class="mt-2 text-sm leading-relaxed">{edu.major} · {edu.period}</p>
                </div>
            ))
        }
    </section>

    <section>
        <h2 class="mb-5 font-serif text-xl italic sm:text-2xl">联系方式</h2>
        <div class="border-main bg-muted border border-dashed p-5">
            <p class="mb-5 text-sm leading-relaxed">如果你对我的经历或项目感兴趣，可以通过邮箱或 GitHub 联系我。</p>
            <div class="flex flex-wrap gap-3">
                <Button href="mailto:3916048194@qq.com">发送邮件</Button>
                <Button href="https://github.com/yuanran32">查看 GitHub</Button>
            </div>
        </div>
    </section>
</article>
