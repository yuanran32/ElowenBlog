---
import { type CollectionEntry } from 'astro:content';
import { withBase } from '../utils/common-utils';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description, techStack = [], githubUrl, demoUrl } = project.data;
const TitleTag = headingLevel;
const projectUrl = withBase(`/projects/${project.id}/`);
---

<div class:list={['group border-main rounded-lg border p-5 transition hover:shadow-md', className]}>
    <div class="mb-3 flex items-start justify-between gap-4">
        <a href={projectUrl}>
            <TitleTag class="font-serif text-lg leading-tight font-bold sm:text-xl">
                {title}
            </TitleTag>
        </a>
        <div class="flex shrink-0 items-center gap-2">
            {
                githubUrl && (
                    <a href={githubUrl} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-muted hover:text-main transition">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
                        </svg>
                    </a>
                )
            }
            {
                demoUrl && (
                    <a href={demoUrl} target="_blank" rel="noopener noreferrer" aria-label="在线演示" class="text-muted hover:text-main transition">
                        <svg
                            class="h-5 w-5"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <>
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                <polyline points="15 3 21 3 21 9" />
                                <line x1="10" y1="14" x2="21" y2="3" />
                            </>
                        </svg>
                    </a>
                )
            }
        </div>
    </div>
    {description && <p class="text-muted mb-4 text-sm leading-relaxed">{description}</p>}
    {
        techStack.length > 0 && (
            <div class="mt-auto flex flex-wrap gap-2">
                {techStack.slice(0, 5).map((tech) => (
                    <span class="border-main rounded-full border px-2.5 py-0.5 text-xs">{tech}</span>
                ))}
            </div>
        )
    }
</div>
