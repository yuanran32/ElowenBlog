---
import { type CollectionEntry } from 'astro:content';
import { withBase } from '../utils/common-utils';
import { createPostDescription, getReadingTime } from '../utils/data-utils';
import CoverFallback from './CoverFallback.astro';
import CustomImage from './CustomImage.astro';
import FormattedDate from './FormattedDate.astro';

type Props = { post: CollectionEntry<'blog'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { post, class: className, headingLevel = 'h2' } = Astro.props;
const { title, publishDate, series, tags = [], draft, cover } = post.data;
const TitleTag = headingLevel;
const postUrl = withBase(`/blog/${post.id}/`);
const readingTime = getReadingTime(post.body);
const description = createPostDescription(post);
---

<a class:list={['group border-main flex flex-col overflow-hidden rounded-lg border transition hover:shadow-md', className]} href={postUrl}>
    <div class="overflow-hidden">
        {
            cover ? (
                <CustomImage
                    class="aspect-[16/9] w-full object-cover transition duration-300 group-hover:scale-105"
                    src={cover}
                    alt={title}
                    width={800}
                    height={450}
                    widths={[400, 800]}
                    sizes="(min-width: 1024px) 22rem, (min-width: 640px) 45vw, 100vw"
                />
            ) : (
                <CoverFallback class="transition duration-300 group-hover:scale-105" title={title} series={series} />
            )
        }
    </div>
    <div class="flex grow flex-col p-5">
        <TitleTag
            class="font-serif text-lg leading-tight font-medium group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4 sm:text-xl"
        >
            {title}
        </TitleTag>
        <div class="text-muted mt-1 text-sm leading-normal">
            {draft && <span class="mr-2">草稿</span>}
            <FormattedDate date={publishDate} />
            {series && <span> · {series}</span>}
            <span> · {readingTime} 分钟阅读</span>
        </div>
        {description && <p class="mt-3 line-clamp-3 text-sm leading-normal">{description}</p>}
        {
            tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                    {tags.slice(0, 3).map((tag) => (
                        <span class="border-main rounded-full border px-2.5 py-0.5 text-xs">{tag}</span>
                    ))}
                </div>
            )
        }
    </div>
</a>
